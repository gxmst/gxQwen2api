# Server
PORT=31998
ADDRESS=0.0.0.0

# Logging: info, debug
LOG_LEVEL=info
LOG_REQUESTS=true

# Retry
MAX_RETRIES=5
RETRY_DELAY_MS=1000

# Auth
# Set to false to disable Qwen OAuth and use direct API key auth
QWEN_CODE_AUTH_USE=true

# API Key (optional — comma-separated for multiple)
API_KEY=

# Model
DEFAULT_MODEL=coder-model

# Credentials directory (scanned for *.json files)
CREDS_DIR=~/.qwen

# Admin dashboard
ADMIN_ENABLED=true
ADMIN_PASSWORD=

# Docker only
HOST_ADDRESS=0.0.0.0
HOST_PORT=31998
