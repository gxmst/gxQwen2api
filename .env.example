# Server
PORT=31998
ADDRESS=0.0.0.0

# Logging: info, debug
LOG_LEVEL=info
LOG_REQUESTS=true

# Retry
MAX_RETRIES=5
RETRY_DELAY_MS=1000
# Isolation duration for quota-exhausted accounts (seconds, default 4h)
QUOTA_COOLDOWN_SECONDS=14400

# Auth
# Set to false to disable Qwen OAuth and use direct API key auth
QWEN_CODE_AUTH_USE=true

# API Key (optional — comma-separated for multiple)
API_KEY=

# Model
DEFAULT_MODEL=coder-model

# Credentials directory (scanned for *.json files)
# Recommended for local/self-hosted use: keep credentials under the project data dir
CREDS_DIR=./data/creds

# DeepSeek Web provider
# Enable DeepSeek chat web provider by placing credential files in CREDS_DIR.
# Each file should contain: {"email": "...", "password": "..."}
# The provider will auto-login and manage sessions.

# Admin dashboard
ADMIN_ENABLED=true
ADMIN_PASSWORD=

# Auto-refresh (background token keep-alive)
# Refreshes tokens before they expire so accounts stay healthy
AUTO_REFRESH_ENABLED=true
AUTO_REFRESH_INTERVAL_SECONDS=300
AUTO_REFRESH_THRESHOLD_MINUTES=30

# Docker only
HOST_ADDRESS=0.0.0.0
HOST_PORT=31998
